// GearHead App - Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SPECTATOR
  EXHIBITOR
}

enum VehicleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  PENDING
  CONFIRMED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(SPECTATOR)
  createdAt    DateTime @default(now())

  vehicles Vehicle[]
  tickets  Ticket[]

  @@index([email])
}

model Vehicle {
  id         String        @id @default(cuid())
  userId     String
  model      String
  brand      String
  year       Int
  mods       Json?         // JSON para modificaciones personalizadas
  photos     String[]      // URLs de fotos
  status     VehicleStatus @default(PENDING)
  approvedAt DateTime?
  createdAt  DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId, status])
}

model Event {
  id          String      @id @default(cuid())
  name        String
  description String?
  date        DateTime
  venue       String
  capacity    Int
  ticketPrice Decimal     @db.Decimal(10, 2)
  status      EventStatus @default(DRAFT)
  createdAt   DateTime    @default(now())

  tickets      Ticket[]
  applications Application[]

  @@index([status, date])
}

model Ticket {
  id          String      @id @default(cuid())
  userId      String
  eventId     String
  code        String      @unique
  status      TicketStatus @default(CONFIRMED)
  purchasedAt DateTime    @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, status])
  @@index([code])
}

model Application {
  id         String            @id @default(cuid())
  vehicleId  String
  eventId    String
  status     ApplicationStatus @default(PENDING)
  submittedAt DateTime        @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, eventId])
  @@index([eventId, status])
}
