{
  "name": "gearhead-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/mobile"
  ],
  "devDependencies": {
    "prisma": "^6.1.0"
  },
  "scripts": {
    "api:start": "npm run start -w api",
    "api:dev": "npm run start:dev -w api",
    "api:test": "npm run test -w api",
    "mobile:start": "npm run start -w mobile",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d"
  }
}
